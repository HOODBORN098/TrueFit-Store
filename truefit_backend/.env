# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production

# Set to False in production
DEBUG=True

# Comma-separated allowed hostnames (use * only for development)
# Example production: ALLOWED_HOSTS=truefit.co.ke,www.truefit.co.ke
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated allowed CORS origins for the Django API
# Must match where your React frontend is served from
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://truefit.co.ke
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Set to 'postgresql' to use PostgreSQL (recommended for production)
# Set to 'mysql' to use MySQL/MariaDB
# Set to 'sqlite' to use a local file-based SQLite database (easiest for development)
DB_ENGINE=postgresql

# PostgreSQL settings (used when DB_ENGINE=postgresql)
DB_NAME=truefit_db
DB_USER=truefit_user
DB_PASSWORD=truefit123
DB_HOST=localhost
DB_PORT=5432

# MySQL settings (only required when DB_ENGINE=mysql)
# DB_NAME=truefit_db
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_HOST=localhost
